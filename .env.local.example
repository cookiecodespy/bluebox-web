# Supabase — captura de leads del formulario de contacto.
# 1) Crea un proyecto en https://supabase.com
# 2) Corre supabase/schema.sql en el SQL editor
# 3) Project Settings → API: copia la URL y la anon/public key aquí
# 4) Copia este archivo a .env.local y reinicia el dev server
#
# Sin estas variables, el formulario funciona igual (cae a mailto).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
